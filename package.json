{
  "name": "multi-model-for-copilot",
  "displayName": "Multi-Model BYOK for Copilot Chat",
  "description": "Pick DeepSeek V4, MiMo V2.5, and Qwen models from the Copilot Chat model picker. Vision, thinking mode, agent tools — zero config, BYOK.",
  "icon": "resources/icon.png",
  "version": "0.7.0",
  "publisher": "WindSnowLi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WindSnowLi/multi-model-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "deepseek",
    "deepseek v4",
    "mimo",
    "xiaomi",
    "multi-model",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "multi-model",
        "displayName": "Multi-Model"
      }
    ],
    "commands": [
      {
        "command": "multi-model-for-copilot.setApiKey",
        "title": "%multi-model-for-copilot.command.setApiKey%"
      },
      {
        "command": "multi-model-for-copilot.getApiKey",
        "title": "%multi-model-for-copilot.command.getApiKey%"
      },
      {
        "command": "multi-model-for-copilot.clearApiKey",
        "title": "%multi-model-for-copilot.command.clearApiKey%"
      },
      {
        "command": "multi-model-for-copilot.setMiMoApiKey",
        "title": "%multi-model-for-copilot.command.setMiMoApiKey%"
      },
      {
        "command": "multi-model-for-copilot.clearMiMoApiKey",
        "title": "%multi-model-for-copilot.command.clearMiMoApiKey%"
      },
      {
        "command": "multi-model-for-copilot.setQwenApiKey",
        "title": "%multi-model-for-copilot.command.setQwenApiKey%"
      },
      {
        "command": "multi-model-for-copilot.clearQwenApiKey",
        "title": "%multi-model-for-copilot.command.clearQwenApiKey%"
      },
      {
        "command": "multi-model-for-copilot.addCustomModel",
        "title": "%multi-model-for-copilot.command.addCustomModel%"
      },
      {
        "command": "multi-model-for-copilot.removeCustomModel",
        "title": "%multi-model-for-copilot.command.removeCustomModel%"
      },
      {
        "command": "multi-model-for-copilot.discoverModels",
        "title": "%multi-model-for-copilot.command.discoverModels%"
      },
      {
        "command": "multi-model-for-copilot.setVisionModel",
        "title": "%multi-model-for-copilot.command.setVisionModel%"
      },
      {
        "command": "multi-model-for-copilot.openSettings",
        "title": "%multi-model-for-copilot.command.openSettings%"
      },
      {
        "command": "multi-model-for-copilot.showLogs",
        "title": "%multi-model-for-copilot.command.showLogs%"
      },
      {
        "command": "multi-model-for-copilot.openRequestDumpsFolder",
        "title": "%multi-model-for-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "gettingStarted",
        "title": "%multi-model-for-copilot.walkthrough.title%",
        "description": "%multi-model-for-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%multi-model-for-copilot.walkthrough.setApiKey.title%",
            "description": "%multi-model-for-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:multi-model-for-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%multi-model-for-copilot.walkthrough.showModels.title%",
            "description": "%multi-model-for-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%multi-model-for-copilot.walkthrough.advancedSettings.title%",
            "description": "%multi-model-for-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%multi-model-for-copilot.config.title%",
      "properties": {
        "multi-model-for-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "%multi-model-for-copilot.config.baseUrl.description%"
        },
        "multi-model-for-copilot.mimoBaseUrl": {
          "type": "string",
          "default": "https://token-plan-cn.xiaomimimo.com/v1",
          "description": "%multi-model-for-copilot.config.mimoBaseUrl.description%"
        },
        "multi-model-for-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%multi-model-for-copilot.config.maxTokens.description%"
        },
        "multi-model-for-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%multi-model-for-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "multi-model-for-copilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "deepseek-v4-flash": "deepseek-v4-flash",
            "deepseek-v4-pro": "deepseek-v4-pro",
            "mimo-v2.5-pro": "mimo-v2.5-pro",
            "mimo-v2.5": "mimo-v2.5"
          },
          "description": "%multi-model-for-copilot.config.modelIdOverrides.description%",
          "additionalProperties": false,
          "properties": {
            "deepseek-v4-flash": {
              "type": "string",
              "description": "%multi-model-for-copilot.config.modelIdOverrides.deepseek-v4-flash.description%"
            },
            "deepseek-v4-pro": {
              "type": "string",
              "description": "%multi-model-for-copilot.config.modelIdOverrides.deepseek-v4-pro.description%"
            },
            "mimo-v2.5-pro": {
              "type": "string",
              "description": "%multi-model-for-copilot.config.modelIdOverrides.mimo-v2.5-pro.description%"
            },
            "mimo-v2.5": {
              "type": "string",
              "description": "%multi-model-for-copilot.config.modelIdOverrides.mimo-v2.5.description%"
            }
          }
        },
        "multi-model-for-copilot.customModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "baseUrl",
              "modelId"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique model identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name in model picker"
              },
              "baseUrl": {
                "type": "string",
                "description": "API base URL (e.g. https://api.example.com/v1)"
              },
              "modelId": {
                "type": "string",
                "description": "Model ID sent in API request"
              },
              "authHeader": {
                "type": "string",
                "default": "Authorization",
                "description": "Auth header name"
              },
              "authPrefix": {
                "type": "string",
                "default": "Bearer ",
                "description": "Prefix before API key (e.g. 'Bearer ' or '')"
              },
              "maxInputTokens": {
                "type": "number",
                "default": 128000
              },
              "maxOutputTokens": {
                "type": "number",
                "default": 8192
              },
              "toolCalling": {
                "default": false,
                "description": "Tool calling support (true/false or number)"
              },
              "imageInput": {
                "type": "boolean",
                "default": false
              },
              "thinking": {
                "type": "boolean",
                "default": false
              },
              "requiresThinkingParam": {
                "type": "boolean",
                "default": false
              },
              "useMaxCompletionTokens": {
                "type": "boolean",
                "default": false,
                "description": "Use max_completion_tokens instead of max_tokens"
              },
              "detail": {
                "type": "string",
                "description": "Short description shown in model picker"
              }
            }
          },
          "markdownDescription": "%multi-model-for-copilot.config.customModels.description%"
        },
        "multi-model-for-copilot.visionModel": {
          "type": "string",
          "default": "",
          "tags": [
            "advanced"
          ],
          "markdownDescription": "%multi-model-for-copilot.config.visionModel.description%"
        },
        "multi-model-for-copilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe all image attachments in this message.\n\nIf there is one image, describe it directly.\nIf there are multiple images:\n1. Describe each image separately, preserving their order.\n2. Then provide a combined description explaining the overall context and relationships across the images.\n\nReturn one concise factual description suitable for inserting into a text-only chat prompt. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
          "markdownDescription": "%multi-model-for-copilot.config.visionPrompt.description%"
        },
        "multi-model-for-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%multi-model-for-copilot.config.debugMode.minimal.label%",
            "%multi-model-for-copilot.config.debugMode.metadata.label%",
            "%multi-model-for-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%multi-model-for-copilot.config.debugMode.minimal.description%",
            "%multi-model-for-copilot.config.debugMode.metadata.description%",
            "%multi-model-for-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%multi-model-for-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "bash .github/scripts/prepare-marketplace-readme.sh && npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "oxlint",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "package": "vsce package --readme-path dist/README.marketplace.md -o dist/",
    "login": "vsce login Vizards"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "0.10.12",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}